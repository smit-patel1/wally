<?xml version="1.0" encoding="utf-8"?>
<robot name="wally" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find wally_bringup)/urdf/macros.xacro"/>

  <!-- Instantiate the Leo Rover with Wally's sensors -->
  <xacro:leo default_antenna="true"
             rockers_fixed="true"
             footprint_link="true"
             mecanum_wheels="false"/>

</robot>
